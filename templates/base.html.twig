<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Philadelphia Pharma — Invitation</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com">
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/aos@2.3.1/dist/aos.css" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://unpkg.com/aos@2.3.1/dist/aos.css"></noscript>
    <link rel="stylesheet" href="{{ asset('assets/css/main.css') }}">
</head>
<body>

{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="site-flash site-flash--{{ label }}" role="status">{{ message }}</div>
    {% endfor %}
{% endfor %}

<div class="page-preloader" id="pagePreloader">
    <div class="page-preloader__inner">
        <div class="heartbeat-loader">
            <svg class="heartbeat-loader__svg" viewBox="0 0 320 80" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path class="heartbeat-loader__base" d="M0 40 H320" />
                <path class="heartbeat-loader__path"
                      d="M0 40 H95 L110 40 L120 28 L132 56 L145 10 L160 66 L176 40 H320" />
            </svg>
            <div class="heartbeat-loader__heart" aria-hidden="true">
                <img src="{{ asset('assets/images/heart.png') }}" alt="" width="96" height="96" decoding="async" fetchpriority="low" loading="eager">
            </div>
        </div>
        <span class="page-preloader__text">Chargement de l'invitation</span>
    </div>
</div>

<section class="hero" id="heroSection">
    <div class="hero__logo hero__logo--client">
        <img src="{{ asset('assets/images/logo-white.png') }}" alt="Philadelphia Pharma" width="180" height="48" decoding="async" fetchpriority="high" loading="eager">
    </div>
    <div class="hero__agency">
        <img class="hero__agency-mark" src="{{ asset('assets/images/logo evenma.png') }}" alt="Evenma — agence événementielle" width="240" height="64" decoding="async" fetchpriority="low" loading="eager">
    </div>

    <div class="hero__grid-lines"></div>
    <div class="hero__overlay-blur hero__overlay-blur--one"></div>
    <div class="hero__overlay-blur hero__overlay-blur--two"></div>

    <div class="container">
        <div class="hero__layout">

            <div class="hero__content">
                <span class="hero__eyebrow reveal reveal--up stagger-0">Invitation officielle 2026</span>

                <h1 class="hero__title hero__title--neon reveal reveal--left stagger-1" aria-label="Invitation">
                    <span class="hero__letter hero__letter--1">I</span>
                    <span class="hero__letter hero__letter--2">n</span>
                    <span class="hero__letter hero__letter--3">v</span>
                    <span class="hero__letter hero__letter--4">i</span>
                    <span class="hero__letter hero__letter--5">t</span>
                    <span class="hero__letter hero__letter--6">a</span>
                    <span class="hero__letter hero__letter--7">t</span>
                    <span class="hero__letter hero__letter--8">i</span>
                    <span class="hero__letter hero__letter--9">o</span>
                    <span class="hero__letter hero__letter--10">n</span>
                </h1>

                <p class="reveal reveal--up stagger-2">
                    Les Laboratoires <span>PHILADELPHIA PHARMA</span> ont le plaisir de vous inviter
                    à la 5ème édition de leur Journée Cardio-métabolique de Cap-Bon.
                </p>

                <div class="hero__actions reveal reveal--up stagger-3">
                    <a href="#programme" class="btn btn--primary">Découvrir l'événement</a>
                    <a href="#register" class="btn btn--secondary">Confirmer ma présence</a>
                </div>

                <div class="countdown reveal reveal--up stagger-4" id="countdown">
                    <div class="countdown__label">L'événement commence dans</div>
                    <div class="countdown__track">
                        <div class="countdown__cell">
                            <span class="countdown__digit" id="days">--</span>
                            <span class="countdown__unit">Jours</span>
                        </div>
                        <span class="countdown__sep">:</span>
                        <div class="countdown__cell">
                            <span class="countdown__digit" id="hours">--</span>
                            <span class="countdown__unit">Heures</span>
                        </div>
                        <span class="countdown__sep">:</span>
                        <div class="countdown__cell">
                            <span class="countdown__digit" id="minutes">--</span>
                            <span class="countdown__unit">Min</span>
                        </div>
                        <span class="countdown__sep">:</span>
                        <div class="countdown__cell">
                            <span class="countdown__digit" id="seconds">--</span>
                            <span class="countdown__unit">Sec</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="hero__side reveal reveal--right stagger-2">
                <div class="orbit-glow orbit-glow--1"></div>
                <div class="orbit-glow orbit-glow--2"></div>

                <div class="side-glow side-glow--one"></div>
                <div class="side-glow side-glow--two"></div>

                <div class="event-card" id="event-card">
                    <div class="event-card__top">
                        <div class="event-card__tag">Édition 2026</div>
                        <div class="event-card__brand"><span>JCM</span>NORD OUEST</div>
                        <div class="event-card__title">Invitation officielle</div>
                    </div>

                    <div class="event-card__body">
                        <div class="info-block reveal reveal--up stagger-5">
                            <div class="info-block__label">Date</div>
                            <div class="info-block__value">25 Avril 2026</div>
                        </div>

                        <div class="info-block info-block--venue reveal reveal--up stagger-6">
                            <figure class="info-block__media">
                                <img class="info-block__img"
                                     src="{{ asset('assets/images/hotel-la-foret.jpg') }}"
                                     alt="Hôtel La Forêt, Aïn Draham"
                                     width="640"
                                     height="400"
                                     sizes="(max-width: 768px) 92vw, min(380px, 42vw)"
                                     loading="eager"
                                     decoding="async"
                                     fetchpriority="low">
                            </figure>
                            <div class="info-block__label">Lieu</div>
                            <div class="info-block__value">Hôtel La Forêt</div>
                            <div class="info-block__sub">
                                Aïn Draham
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <div class="scroll-hint reveal reveal--up stagger-7" aria-label="Défiler vers le bas">
        <svg width="24" height="38" viewBox="0 0 24 38" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="1" y="1" width="22" height="36" rx="11" stroke="currentColor" stroke-width="1.5"/>
            <circle class="scroll-hint__dot" cx="12" cy="10" r="2.5" fill="currentColor"/>
        </svg>
        <span class="scroll-hint__text">Défiler</span>
    </div>
</section>

{% set partner_logos = [
    { file: 'inovia.png', alt: 'Inovia' },
    { file: 'arvene.png', alt: 'Arvene' },
    { file: 'duofor.png', alt: 'Duofor' },
    { file: 'vildamet.png', alt: 'Vildamet' },
] %}
<section class="partners" id="partners" aria-label="Partenaires" data-aos="fade-up">
    <div class="partners__viewport">
        <div class="partners__track">
            <ul class="partners__list" role="list">
                {% for logo in partner_logos %}
                <li class="partners__item">
                    <img class="partners__logo"
                         src="{{ asset('assets/images/partners/' ~ logo.file) }}"
                         alt="{{ logo.alt }}"
                         width="200"
                         height="80"
                         sizes="(max-width: 768px) 36vw, 200px"
                         loading="lazy"
                         decoding="async"
                         fetchpriority="low">
                </li>
                {% endfor %}
            </ul>
            <ul class="partners__list partners__list--clone" role="presentation" aria-hidden="true">
                {% for logo in partner_logos %}
                <li class="partners__item">
                    <img class="partners__logo"
                         src="{{ asset('assets/images/partners/' ~ logo.file) }}"
                         alt=""
                         width="200"
                         height="80"
                         sizes="(max-width: 768px) 36vw, 200px"
                         loading="lazy"
                         decoding="async"
                         fetchpriority="low">
                </li>
                {% endfor %}
            </ul>
        </div>
    </div>
</section>

<!-- Programme section -->
<section class="programme programme--scroll-driven" id="programme">
    <div class="programme__vanta" id="programmeVanta"></div>

    <div class="container">
        <header class="programme__header" data-aos="fade-up">
            <p class="programme__intro">
                Les Laboratoires <strong>PHILADELPHIA PHARMA</strong> ont le plaisir de vous inviter
                à la 5<sup>e</sup> édition de leur Journée Cardio-métabolique du Cap-Bon.
            </p>
            <h2 class="programme__event-title">
                <span class="programme__event-title-line">Doctor's</span>
                <span class="programme__event-title-line programme__event-title-line--accent">Battle</span>
            </h2>
            <p class="programme__date">Samedi 25 avril 2026</p>
            <p class="programme__venue">Hôtel La Forêt · Aïn Draham</p>
        </header>

        <div class="programme__badge" data-aos="fade-up" data-aos-delay="120">Au programme</div>

        <div class="schedule">
            <article class="schedule__item schedule__item--accent">
                <span class="schedule__time">14h</span>
                <div class="schedule__body">
                    <h3 class="schedule__heading">Check-in à l'hôtel</h3>
                </div>
            </article>

            <article class="schedule__item">
                <span class="schedule__time">19h00</span>
                <div class="schedule__body">
                    <h3 class="schedule__heading">Cocktail d'accueil</h3>
                </div>
            </article>

            <article class="schedule__item schedule__item--session">
                <span class="schedule__time">19h30</span>
                <div class="schedule__body">
                    <div class="schedule__session-row">
                        <figure class="schedule__avatar-wrap">
                            <img class="schedule__avatar"
                                 src="{{ asset('assets/images/speakers/speaker1.jpg') }}"
                                 alt="Portrait du Dr Badr Ben Kaab"
                                 width="56"
                                 height="56"
                                 sizes="56px"
                                 loading="lazy"
                                 decoding="async"
                                 fetchpriority="low">
                        </figure>
                        <div class="schedule__session-main">
                            <h3 class="schedule__session">From case to choice : HTA</h3>
                            <p class="schedule__speaker">
                                <span class="schedule__speaker-label">Assurée par</span>
                                <strong class="schedule__speaker-name">Dr Badr Ben Kaab</strong>
                            </p>
                            <p class="schedule__affiliation">
                                Professeur agrégé en néphrologie, service de cardiologie à l'hôpital des Forces de sécurité intérieure, La Marsa.
                            </p>
                        </div>
                    </div>
                </div>
            </article>

            <article class="schedule__item schedule__item--session">
                <span class="schedule__time">20h00</span>
                <div class="schedule__body">
                    <div class="schedule__session-row">
                        <figure class="schedule__avatar-wrap">
                            <img class="schedule__avatar"
                                 src="{{ asset('assets/images/speakers/speaker2.png') }}"
                                 alt="Portrait du Dr Fatma Mnif"
                                 width="56"
                                 height="56"
                                 sizes="56px"
                                 loading="lazy"
                                 decoding="async"
                                 fetchpriority="low">
                        </figure>
                        <div class="schedule__session-main">
                            <h3 class="schedule__session">From case to choice : diabète</h3>
                            <p class="schedule__speaker">
                                <span class="schedule__speaker-label">Assurée par</span>
                                <strong class="schedule__speaker-name">Dr Fatma Mnif</strong>
                            </p>
                            <p class="schedule__affiliation">
                                Cheffe de service d'endocrinologie à l'hôpital militaire universitaire de Sfax et présidente de l'AEDS (Amicale des endocrino-diabétologues de Sfax).
                            </p>
                        </div>
                    </div>
                </div>
            </article>

            <article id="scheduleGala"
                     class="schedule__item schedule__item--accent schedule__item--gala"
                     data-aos="zoom-in-up"
                     data-aos-duration="850"
                     data-aos-delay="200">
                <span class="schedule__time">20h30</span>
                <div class="schedule__body">
                    <h3 class="schedule__heading">Dîner gala</h3>
                    <p class="schedule__detail">
                        Animé par la star <strong>Mehdi Ayachi</strong> et la troupe <strong>« Houriyet Tarab »</strong>.
                    </p>
                    {% if performance_youtube_id %}
                    <figure class="schedule__gala-media schedule__gala-media--video">
                        <button type="button"
                                class="performance-spotlight__trigger performance-spotlight__trigger--schedule"
                                id="performanceVideoOpen"
                                aria-haspopup="dialog"
                                aria-controls="performanceVideoModal"
                                data-youtube-id="{{ performance_youtube_id|e('html_attr') }}">
                            <span class="performance-spotlight__media">
                                <img class="schedule__gala-img performance-spotlight__img"
                                     src="{{ asset('assets/images/mehdi_ayachi.jpg') }}"
                                     alt="Mehdi Ayachi"
                                     width="960"
                                     height="540"
                                     sizes="(max-width: 768px) 100vw, min(560px, 92vw)"
                                     loading="lazy"
                                     decoding="async"
                                     fetchpriority="low">
                            </span>
                            <span class="performance-spotlight__play">
                                <span class="performance-spotlight__play-icon" aria-hidden="true">▶</span>
                                <span class="performance-spotlight__play-label">Voir la performance</span>
                            </span>
                        </button>
                        <figcaption class="schedule__gala-caption">Mehdi Ayachi</figcaption>
                    </figure>
                    {% else %}
                    <figure class="schedule__gala-media">
                        <img class="schedule__gala-img"
                             src="{{ asset('assets/images/mehdi_ayachi.jpg') }}"
                             alt="Mehdi Ayachi"
                             width="960"
                             height="540"
                             sizes="(max-width: 768px) 100vw, min(560px, 92vw)"
                             loading="lazy"
                             decoding="async"
                             fetchpriority="low">
                        <figcaption class="schedule__gala-caption">Mehdi Ayachi</figcaption>
                    </figure>
                    {% endif %}
                </div>
            </article>

            <article class="schedule__item">
                <span class="schedule__time">Minuit</span>
                <div class="schedule__body">
                    <h3 class="schedule__heading">Clôture</h3>
                    <p class="schedule__detail">Fin de la 5<sup>e</sup> édition de la Journée Cardio-métabolique.</p>
                </div>
            </article>
        </div>

        <div class="programme__cta" data-aos="fade-up" data-aos-delay="80">
            <a href="#register" class="btn btn--primary">Confirmer ma présence</a>
        </div>
    </div>
</section>

<audio id="registrationThemeAudio" preload="none" playsinline hidden>
    <source src="{{ asset('assets/audio/audio-4.mp3') }}" type="audio/mpeg">
</audio>

<div class="registration-sheet" id="registrationSheet" role="dialog" aria-modal="true" aria-labelledby="registrationSheetTitle" aria-hidden="true">
    <div class="registration-sheet__backdrop" id="registrationSheetBackdrop" tabindex="-1"></div>
    <div class="registration-sheet__panel" id="register">
        <button type="button" class="registration-sheet__close" id="registrationSheetClose" aria-label="Fermer">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>

        <div class="registration-sheet__inner">
            <div class="registration-sheet__sound-hint">
                <div class="audio-viz" id="registrationAudioViz" role="img" aria-label="En lecture : Mehdi Ayachi — Weld 3rab">
                    <span class="audio-viz__bar"></span>
                    <span class="audio-viz__bar"></span>
                    <span class="audio-viz__bar"></span>
                    <span class="audio-viz__bar"></span>
                    <span class="audio-viz__bar"></span>
                </div>
                <span class="registration-sheet__sound-caption">En lecture : DOCTOR’S BATTLE</span>
            </div>
            <span class="registration-sheet__eyebrow">Inscription</span>
            <h2 class="registration-sheet__title" id="registrationSheetTitle">Confirmer votre présence</h2>
            <p class="registration-sheet__lead">
                Choisissez votre formule d'hébergement puis complétez les informations demandées.
            </p>

            <form class="registration-form" id="registrationForm" method="post" action="{{ path('home') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('registration') }}">
                <fieldset class="registration-form__room">
                    <legend class="registration-form__legend">Type d'hébergement</legend>
                    <div class="registration-form__room-grid">
                        <label class="registration-form__room-card">
                            <input type="radio" name="room_type" value="single" checked>
                            <span class="registration-form__room-title">Chambre Single</span>
                            <span class="registration-form__room-desc">Une personne, une chambre individuelle</span>
                        </label>
                        <label class="registration-form__room-card">
                            <input type="radio" name="room_type" value="double">
                            <span class="registration-form__room-title">Chambre double</span>
                            <span class="registration-form__room-desc">Deux participants partageant la même chambre</span>
                        </label>
                    </div>
                </fieldset>

                <div class="registration-form__blocks" id="registrationFormBlocks">
                    <div class="registration-form__block" id="registrationBlockSingle" data-room="single">
                        <h3 class="registration-form__block-title">Vos coordonnées</h3>
                        <div class="registration-form__grid">
                            <label class="registration-form__field">
                                <span class="registration-form__label">Prénom <abbr title="obligatoire">*</abbr></span>
                                <input type="text" name="first_name" autocomplete="given-name">
                            </label>
                            <label class="registration-form__field">
                                <span class="registration-form__label">Nom <abbr title="obligatoire">*</abbr></span>
                                <input type="text" name="last_name" autocomplete="family-name">
                            </label>
                            <label class="registration-form__field registration-form__field--full">
                                <span class="registration-form__label">E-mail professionnel <abbr title="obligatoire">*</abbr></span>
                                <input type="email" name="email" autocomplete="email">
                            </label>
                            <label class="registration-form__field">
                                <span class="registration-form__label">Téléphone <abbr title="obligatoire">*</abbr></span>
                                <input type="tel" name="phone" autocomplete="tel">
                            </label>
                            <label class="registration-form__field">
                                <span class="registration-form__label">Établissement / Service</span>
                                <input type="text" name="institution" autocomplete="organization">
                            </label>
                            <label class="registration-form__field registration-form__field--full">
                                <span class="registration-form__label">Demandes particulières (allergies, accessibilité…)</span>
                                <textarea name="notes" rows="2"></textarea>
                            </label>
                        </div>
                    </div>

                    <div class="registration-form__block registration-form__block--hidden" id="registrationBlockDouble" data-room="double">
                        <h3 class="registration-form__block-title">Participant 1</h3>
                        <div class="registration-form__grid">
                            <label class="registration-form__field">
                                <span class="registration-form__label">Prénom <abbr title="obligatoire">*</abbr></span>
                                <input type="text" name="p1_first_name" autocomplete="given-name">
                            </label>
                            <label class="registration-form__field">
                                <span class="registration-form__label">Nom <abbr title="obligatoire">*</abbr></span>
                                <input type="text" name="p1_last_name" autocomplete="family-name">
                            </label>
                            <label class="registration-form__field registration-form__field--full">
                                <span class="registration-form__label">E-mail <abbr title="obligatoire">*</abbr></span>
                                <input type="email" name="p1_email" autocomplete="email">
                            </label>
                        </div>
                        <h3 class="registration-form__block-title registration-form__block-title--second">Participant 2</h3>
                        <div class="registration-form__grid">
                            <label class="registration-form__field">
                                <span class="registration-form__label">Prénom <abbr title="obligatoire">*</abbr></span>
                                <input type="text" name="p2_first_name" autocomplete="given-name">
                            </label>
                            <label class="registration-form__field">
                                <span class="registration-form__label">Nom <abbr title="obligatoire">*</abbr></span>
                                <input type="text" name="p2_last_name" autocomplete="family-name">
                            </label>
                            <label class="registration-form__field registration-form__field--full">
                                <span class="registration-form__label">E-mail <abbr title="obligatoire">*</abbr></span>
                                <input type="email" name="p2_email" autocomplete="email">
                            </label>
                            <label class="registration-form__field">
                                <span class="registration-form__label">Téléphone (contact commun)</span>
                                <input type="tel" name="double_phone" autocomplete="tel">
                            </label>
                            <label class="registration-form__field registration-form__field--full">
                                <span class="registration-form__label">Établissement / Service</span>
                                <input type="text" name="double_institution" autocomplete="organization">
                            </label>
                            <label class="registration-form__field registration-form__field--full">
                                <span class="registration-form__label">Demandes particulières</span>
                                <textarea name="double_notes" rows="2"></textarea>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="registration-form__actions">
                    <button type="submit" class="btn btn--primary">Envoyer la demande d'inscription</button>
                </div>
            </form>
        </div>
    </div>
</div>

{% if performance_youtube_id %}
<div id="performanceVideoModal"
     class="video-modal"
     role="dialog"
     aria-modal="true"
     aria-labelledby="performanceVideoTitle"
     aria-hidden="true">
    <div class="video-modal__backdrop" data-video-modal-close tabindex="-1"></div>
    <div class="video-modal__panel">
        <h2 id="performanceVideoTitle" class="video-modal__title-sr">Performance — Mehdi Ayachi</h2>
        <button type="button" class="video-modal__close" id="performanceVideoClose" aria-label="Fermer la vidéo">×</button>
        <div class="video-modal__embed" id="performanceVideoEmbed"></div>
    </div>
</div>
{% endif %}

<script defer src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script defer src="{{ asset('assets/js/main.js') }}"></script>

</body>
</html>