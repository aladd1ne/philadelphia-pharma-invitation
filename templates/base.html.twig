<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Invitation Hero Section</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('assets/css/main.css') }}">
</head>
<body>
<div class="page-preloader" id="pagePreloader">
    <div class="page-preloader__inner">
        <div class="page-preloader__spinner"></div>
        <span>Chargement de l’invitation</span>
    </div>
</div>

<section class="hero">
    <div class="hero__grid-lines"></div>
    <div class="hero__overlay-blur hero__overlay-blur--one"></div>
    <div class="hero__overlay-blur hero__overlay-blur--two"></div>

    <div class="container">
        <div class="hero__layout">
            <div class="hero__content reveal reveal--left">
                <span class="hero__eyebrow">Invitation officielle 2026</span>

                <h1>Invitation</h1>

                <p>
                    Les Laboratoires PHILADELPHIA PHARMA ont le plaisir de vous inviter à la 5ème édition
                    de leur Journée Cardio-métabolique de Cap-Bon.
                </p>

                <div class="hero__actions">
                    <a href="#details" class="btn btn--primary">Découvrir l'événement</a>
                    <a href="#register" class="btn btn--secondary">Confirmer ma présence</a>
                </div>
            </div>

            <div class="hero__side reveal reveal--right">
                <div class="orbit-glow orbit-glow--1"></div>
                <div class="orbit-glow orbit-glow--2"></div>

                <div class="side-glow side-glow--one"></div>
                <div class="side-glow side-glow--two"></div>

                <div class="event-card" id="details">
                    <div class="event-card__top">
                        <div class="event-card__tag">Édition 2026</div>
                        <div class="event-card__brand"><span>JCM</span>NORD OUEST</div>
                        <div class="event-card__title">Invitation officielle</div>
                    </div>

                    <div class="event-card__body">
                        <div class="info-block reveal reveal--up delay-1">
                            <div class="info-block__label">Date</div>
                            <div class="info-block__value">25 Avril 2026</div>
                            <div class="info-block__sub">
                                Une journée pensée pour réunir les professionnels dans un cadre soigné et mémorable.
                            </div>
                        </div>

                        <div class="info-block reveal reveal--up delay-2">
                            <div class="info-block__label">Lieu</div>
                            <div class="info-block__value">Hôtel La Forêt</div>
                            <div class="info-block__sub">
                                Aïn Draham · Accueil, échange, présentation et expérience premium.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="hero__sponsors reveal reveal--up delay-4">
            <div class="hero__sponsors-label">Partenaires</div>

            <div class="sponsors-marquee">
                <div class="sponsors-marquee__track">
                    <div class="sponsor-logo">NOVIA</div>
                    <div class="sponsor-logo">VILDAMET</div>
                    <div class="sponsor-logo">DUO FOR</div>
                    <div class="sponsor-logo">ARAVEN-IC</div>
                    <div class="sponsor-logo">NOVIA</div>
                    <div class="sponsor-logo">VILDAMET</div>
                    <div class="sponsor-logo">DUO FOR</div>
                    <div class="sponsor-logo">ARAVEN-IC</div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    const hero = document.querySelector('.hero');
    const content = document.querySelector('.hero__content');
    const side = document.querySelector('.hero__side');
    const preloader = document.getElementById('pagePreloader');

    window.addEventListener('mousemove', (e) => {
        const x = (e.clientX / window.innerWidth - 0.5) * 12;
        const y = (e.clientY / window.innerHeight - 0.5) * 12;

        if (content) {
            content.style.transform = `translate3d(${x * -0.15}px, ${y * -0.15}px, 0)`;
        }

        if (side) {
            side.style.transform = `translate3d(${x * 0.18}px, ${y * 0.18}px, 0)`;
        }

        if (hero) {
            hero.style.backgroundPosition = `${50 + x * 0.1}% ${50 + y * 0.1}%`;
        }
    });

    window.addEventListener('load', () => {
        document.body.classList.add('is-loaded');

        setTimeout(() => {
            preloader.classList.add('page-preloader--hidden');
        }, 800);
    });
</script>
</body>
</html>


