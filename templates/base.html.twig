<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Philadelphia Pharma — Invitation</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('assets/css/main.css') }}">
</head>
<body>

<div class="page-preloader" id="pagePreloader">
    <div class="page-preloader__inner">
        <div class="heartbeat-loader">
            <svg class="heartbeat-loader__svg" viewBox="0 0 320 80" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path class="heartbeat-loader__base" d="M0 40 H320" />
                <path class="heartbeat-loader__path"
                      d="M0 40 H95 L110 40 L120 28 L132 56 L145 10 L160 66 L176 40 H320" />
            </svg>
            <div class="heartbeat-loader__heart">❤</div>
        </div>
        <span class="page-preloader__text">Chargement de l'invitation</span>
    </div>
</div>

<section class="hero" id="heroSection">
    <div class="hero__logo">
        <img src="{{ asset('assets/images/logo-white.png') }}" alt="Philadelphia Pharma">
    </div>

    <div class="hero__grid-lines"></div>
    <div class="hero__overlay-blur hero__overlay-blur--one"></div>
    <div class="hero__overlay-blur hero__overlay-blur--two"></div>

    <div class="container">
        <div class="hero__layout">

            <div class="hero__content">
                <span class="hero__eyebrow reveal reveal--up stagger-0">Invitation officielle 2026</span>

                <h1 class="hero__title hero__title--neon reveal reveal--left stagger-1" aria-label="Invitation">
                    <span class="hero__letter hero__letter--1">I</span>
                    <span class="hero__letter hero__letter--2">n</span>
                    <span class="hero__letter hero__letter--3">v</span>
                    <span class="hero__letter hero__letter--4">i</span>
                    <span class="hero__letter hero__letter--5">t</span>
                    <span class="hero__letter hero__letter--6">a</span>
                    <span class="hero__letter hero__letter--7">t</span>
                    <span class="hero__letter hero__letter--8">i</span>
                    <span class="hero__letter hero__letter--9">o</span>
                    <span class="hero__letter hero__letter--10">n</span>
                </h1>

                <p class="reveal reveal--up stagger-2">
                    Les Laboratoires <span>PHILADELPHIA PHARMA</span> ont le plaisir de vous inviter
                    à la 5ème édition de leur Journée Cardio-métabolique de Cap-Bon.
                </p>

                <div class="hero__actions reveal reveal--up stagger-3">
                    <a href="#details" class="btn btn--primary">Découvrir l'événement</a>
                    <a href="#register" class="btn btn--secondary">Confirmer ma présence</a>
                </div>

                <div class="countdown reveal reveal--up stagger-4" id="countdown">
                    <div class="countdown__label">L'événement commence dans</div>
                    <div class="countdown__track">
                        <div class="countdown__cell">
                            <span class="countdown__digit" id="days">--</span>
                            <span class="countdown__unit">Jours</span>
                        </div>
                        <span class="countdown__sep">:</span>
                        <div class="countdown__cell">
                            <span class="countdown__digit" id="hours">--</span>
                            <span class="countdown__unit">Heures</span>
                        </div>
                        <span class="countdown__sep">:</span>
                        <div class="countdown__cell">
                            <span class="countdown__digit" id="minutes">--</span>
                            <span class="countdown__unit">Min</span>
                        </div>
                        <span class="countdown__sep">:</span>
                        <div class="countdown__cell">
                            <span class="countdown__digit" id="seconds">--</span>
                            <span class="countdown__unit">Sec</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="hero__side reveal reveal--right stagger-2">
                <div class="orbit-glow orbit-glow--1"></div>
                <div class="orbit-glow orbit-glow--2"></div>

                <div class="side-glow side-glow--one"></div>
                <div class="side-glow side-glow--two"></div>

                <div class="event-card" id="details">
                    <div class="event-card__top">
                        <div class="event-card__tag">Édition 2026</div>
                        <div class="event-card__brand"><span>JCM</span>NORD OUEST</div>
                        <div class="event-card__title">Invitation officielle</div>
                    </div>

                    <div class="event-card__body">
                        <div class="info-block reveal reveal--up stagger-5">
                            <div class="info-block__label">Date</div>
                            <div class="info-block__value">25 Avril 2026</div>
                            <div class="info-block__sub">
                                Une journée pensée pour réunir les professionnels dans un cadre soigné et mémorable.
                            </div>
                        </div>

                        <div class="info-block reveal reveal--up stagger-6">
                            <div class="info-block__label">Lieu</div>
                            <div class="info-block__value">Hôtel La Forêt</div>
                            <div class="info-block__sub">
                                Aïn Draham · Accueil, échange, présentation et expérience premium.
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <div class="scroll-hint reveal reveal--up stagger-7">
        <svg width="24" height="38" viewBox="0 0 24 38" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="1" y="1" width="22" height="36" rx="11" stroke="currentColor" stroke-width="1.5"/>
            <circle class="scroll-hint__dot" cx="12" cy="10" r="2.5" fill="currentColor"/>
        </svg>
        <span class="scroll-hint__text">Défiler</span>
    </div>
</section>

<script>
(function () {
    const hero = document.querySelector('.hero');
    const content = document.querySelector('.hero__content');
    const side = document.querySelector('.hero__side');
    const preloader = document.getElementById('pagePreloader');

    let mouseX = 0, mouseY = 0;
    let currentX = 0, currentY = 0;

    function lerp(a, b, t) {
        return a + (b - a) * t;
    }

    function updateParallax() {
        currentX = lerp(currentX, mouseX, 0.06);
        currentY = lerp(currentY, mouseY, 0.06);

        if (content) {
            content.style.transform =
                'translate3d(' + (currentX * -0.15) + 'px, ' + (currentY * -0.15) + 'px, 0)';
        }
        if (side) {
            side.style.transform =
                'translate3d(' + (currentX * 0.12) + 'px, ' + (currentY * 0.12) + 'px, 0)';
        }
        if (hero) {
            hero.style.backgroundPosition =
                (50 + currentX * 0.06) + '% ' + (50 + currentY * 0.06) + '%';
        }
        requestAnimationFrame(updateParallax);
    }

    window.addEventListener('mousemove', function (e) {
        mouseX = (e.clientX / window.innerWidth  - 0.5) * 10;
        mouseY = (e.clientY / window.innerHeight - 0.5) * 10;
    });

    requestAnimationFrame(updateParallax);

    window.addEventListener('load', function () {
        document.body.classList.add('is-loaded');

        setTimeout(function () {
            if (preloader) {
                preloader.classList.add('page-preloader--hidden');
            }

            setTimeout(function () {
                document.body.classList.add('hero-revealed');
            }, 750);
        }, 1100);
    });

    document.querySelectorAll('a[href^="#"]').forEach(function (anchor) {
        anchor.addEventListener('click', function (e) {
            var target = document.querySelector(this.getAttribute('href'));
            if (target) {
                e.preventDefault();
                target.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });
    });

    function startCountdown() {
        var eventDate = new Date('2026-04-25T09:00:00').getTime();
        var prev = {};

        function setDigit(id, value) {
            var el = document.getElementById(id);
            if (!el) return;
            var str = value.toString().padStart(2, '0');
            if (prev[id] !== str) {
                el.textContent = str;
                el.classList.add('tick');
                setTimeout(function () { el.classList.remove('tick'); }, 200);
                prev[id] = str;
            }
        }

        function update() {
            var diff = eventDate - Date.now();

            if (diff <= 0) {
                var el = document.getElementById('countdown');
                if (el) {
                    el.querySelector('.countdown__track').style.display = 'none';
                    el.querySelector('.countdown__label').textContent = "L'événement a commencé !";
                    el.querySelector('.countdown__label').style.color = 'var(--blue-soft)';
                }
                return;
            }

            setDigit('days',    Math.floor(diff / 86400000));
            setDigit('hours',   Math.floor((diff / 3600000) % 24));
            setDigit('minutes', Math.floor((diff / 60000)   % 60));
            setDigit('seconds', Math.floor((diff / 1000)    % 60));
        }

        update();
        setInterval(update, 1000);
    }

    window.addEventListener('load', startCountdown);
})();
</script>

</body>
</html>
