<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inscription enregistrée — JCM</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('assets/css/main.css') }}">
</head>
<body class="confirmation-body">
    <a href="{{ path('home') }}" class="confirmation-skip">Aller au contenu principal</a>

    <header class="confirmation-header">
        <div class="confirmation-header__logos">
            <a href="{{ path('home') }}" class="confirmation-header__brand" aria-label="Retour à l'accueil — Philadelphia Pharma">
                <img src="{{ asset('assets/images/logo-white.png') }}" alt="" width="140" height="36" decoding="async" class="confirmation-header__logo">
            </a>
            <span class="confirmation-header__sep" aria-hidden="true"></span>
            <a href="{{ path('home') }}" class="confirmation-header__brand confirmation-header__brand--agency" aria-label="Evenma">
                <img src="{{ asset('assets/images/logo evenma.png') }}" alt="" width="150" height="42" decoding="async" class="confirmation-header__logo confirmation-header__logo--agency">
            </a>
        </div>
    </header>

    <main class="confirmation-main" id="main-content">
        <div class="confirmation-card">
            <div class="confirmation-card__icon" aria-hidden="true">
                <svg class="confirmation-card__check" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" focusable="false">
                    <circle cx="32" cy="32" r="30" stroke="currentColor" stroke-width="2" opacity="0.35"/>
                    <path d="M20 33l9 9 15-18" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <p class="confirmation-card__eyebrow">Inscription</p>
            <h1 class="confirmation-card__message confirmation-card__message--hero">
                Merci ! Votre demande d'inscription a bien été enregistrée. Nous vous recontacterons prochainement.
            </h1>

            <div class="confirmation-card__actions">
                {% if programPdfAvailable %}
                    <a href="{{ path('download_event_program') }}"
                       class="confirmation-btn confirmation-btn--primary"
                       download>
                        <span class="confirmation-btn__icon" aria-hidden="true">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        </span>
                        Télécharger le programme de l'événement
                    </a>
                {% else %}
                    <a href="{{ path('home') }}#programme"
                       class="confirmation-btn confirmation-btn--primary">
                        <span class="confirmation-btn__icon" aria-hidden="true">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                        </span>
                        Consulter le programme de l'événement
                    </a>
                {% endif %}

                <a href="{{ path('home') }}" class="confirmation-btn confirmation-btn--ghost">Retour à l'accueil</a>
            </div>
        </div>
    </main>

    <footer class="confirmation-footer">
        <p class="confirmation-footer__note">Philadelphia Pharma — Journée Cardio-métabolique</p>
    </footer>
</body>
</html>
