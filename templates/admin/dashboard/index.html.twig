{% extends 'admin/base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
    <div class="admin-page">
        <h1 class="admin-page__title">Tableau de bord</h1>
        <p class="admin-page__lead">Gérez les inscriptions des médecins et exportez les données.</p>

        <div class="admin-cards">
            <a href="{{ path('admin_doctors_index') }}" class="admin-card">
                <h2 class="admin-card__title">Inscriptions</h2>
                <p class="admin-card__text">Consulter et modifier les fiches enregistrées.</p>
            </a>
            <a href="{{ path('admin_doctors_export') }}" class="admin-card">
                <h2 class="admin-card__title">Export XLSX</h2>
                <p class="admin-card__text">Télécharger la liste complète au format Excel.</p>
            </a>
        </div>
    </div>
{% endblock %}
