{% extends 'admin/base.html.twig' %}
{% set active_nav = 'doctors' %}

{% block title %}Modifier #{{ doctor.id }}{% endblock %}

{% block body %}
    <div class="admin-page">
        <p class="admin-breadcrumb"><a href="{{ path('admin_doctors_index') }}">← Inscriptions</a></p>
        <h1 class="admin-page__title">Fiche #{{ doctor.id }}</h1>
        <p class="admin-page__lead">Créée le {{ doctor.createdAt ? doctor.createdAt|date('d/m/Y à H:i') : '—' }}</p>

        {{ form_start(form, { attr: { class: 'admin-form admin-form--stack' } }) }}
            {{ form_row(form.roomType) }}
            <hr class="admin-sep">
            <h2 class="admin-form__section">Chambre simple</h2>
            {{ form_row(form.firstName) }}
            {{ form_row(form.lastName) }}
            {{ form_row(form.email) }}
            {{ form_row(form.phone) }}
            {{ form_row(form.institution) }}
            {{ form_row(form.notes) }}
            <hr class="admin-sep">
            <h2 class="admin-form__section">Chambre double</h2>
            {{ form_row(form.participant1FirstName) }}
            {{ form_row(form.participant1LastName) }}
            {{ form_row(form.participant1Email) }}
            {{ form_row(form.participant2FirstName) }}
            {{ form_row(form.participant2LastName) }}
            {{ form_row(form.participant2Email) }}
            {{ form_row(form.sharedPhone) }}
            {{ form_row(form.sharedInstitution) }}
            {{ form_row(form.sharedNotes) }}

            <div class="admin-form__actions">
                <button type="submit" class="admin-btn admin-btn--primary">Enregistrer</button>
                <a href="{{ path('admin_doctors_index') }}" class="admin-btn admin-btn--ghost">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
